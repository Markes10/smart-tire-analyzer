# ═══════════════════════════════════════════════════════════════════════════
# Smart Tire Analyzer — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# ⚠️  SETUP INSTRUCTIONS:
#   1. Run the setup script: python scripts/setup_production_env.py
#      (This generates strong secrets for you.)
#   2. Or manually: search and replace "your-domain.com" with your actual domain.
#   3. Fill in all API keys.
#   4. NEVER commit this file to version control (it is in .gitignore).
#   5. Restrict file permissions: chmod 600 .env.production
#
# Usage:
#   cp .env.production .env
#   # Edit .env with your actual values
#   # Then deploy: docker compose -f deployment/docker/docker-compose.yml up -d
#
# ═══════════════════════════════════════════════════════════════════════════

# ── TLS / HTTPS ─────────────────────────────────────────────────────────
# Set your domain and enable HTTPS for production.
# Generate certs with: bash scripts/setup_production_certs.sh your-domain.com
# ⚠️  Replace "your-domain.com" everywhere with your actual domain
DOMAIN=your-domain.com
ENABLE_HTTPS=true                         # Redirect HTTP → HTTPS

# ── Frontend ────────────────────────────────────────────────────────────
# ⚠️  Replace your-domain.com in the line below
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com

# ── Authentication (REQUIRED — enables JWT, API key encryption) ─────────
AUTH_ENABLED=true
# Generate JWT_SECRET:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=                                # ⚠️  REQUIRED — min 32 characters
JWT_ISSUER=smart-tire-analyzer

# ── NextAuth (required for frontend login/sessions) ──────────────────────
# ⚠️  Replace your-domain.com in the line below
NEXTAUTH_URL=https://your-domain.com
# Generate NEXTAUTH_SECRET:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXTAUTH_SECRET=                           # ⚠️  REQUIRED — min 32 characters

# ── Google OAuth (optional) ─────────────────────────────────────────────
# Get keys at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=                          # Your Google OAuth client ID
GOOGLE_CLIENT_SECRET=                      # Server-side only — never in browser
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}

# ── Live Chat LLM ───────────────────────────────────────────────────────
LIVE_CHAT_PROVIDER=gemini
LIVE_CHAT_MODEL=gemini-2.5-flash
LIVE_CHAT_REQUEST_TIMEOUT_MS=45000

# ── Gemini AI API Keys ──────────────────────────────────────────────────
# Comma-separated values for automatic key rotation
GEMINI_API_KEYS=                           # e.g. key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_DAILY_QUOTA=50

# ── Google Maps API Keys ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEYS=                      # e.g. key1,key2

# ── OpenWeatherMap API Keys ─────────────────────────────────────────────
OPENWEATHER_API_KEYS=                      # e.g. key1,key2

# ── Mapillary API Keys ──────────────────────────────────────────────────
MAPILLARY_API_KEYS=                        # e.g. key1,key2

# ── Database ────────────────────────────────────────────────────────────
# For production, ALWAYS use PostgreSQL with TLS:
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/smart_tire
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/smart_tire

# ── Redis Cache ─────────────────────────────────────────────────────────
REDIS_URL=redis://:password@redis:6379/0   # ⚠️  Add a strong password

# ── Backend Server ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4                              # Scale to match CPU cores
# ⚠️  Replace your-domain.com below
BACKEND_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Model Settings ──────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.70
BLUR_THRESHOLD=60
RETRAIN_THRESHOLD=10
AUTO_RETRAIN=true
MODEL_VERSION=1.0.0

# ── Notifications (optional) ────────────────────────────────────────────
NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=notifications@your-domain.com
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=alerts@your-domain.com
NOTIFICATION_EMAIL_TO=admin@your-domain.com
SLACK_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=

# ── Image Processing ────────────────────────────────────────────────────
IMAGE_OPTIMIZER_ENABLED=true
IMAGE_OPTIMIZER_MAX_DIMENSION=2048
MAX_IMAGE_SIZE_MB=10

# ── Advanced (change only if you know what you're doing) ──────────────────
DEBUG=false
LOG_LEVEL=INFO
API_KEY=
AUTO_RETRAIN_TRAIN=true
AUTO_RETRAIN_STAGE1_EPOCHS=2
AUTO_RETRAIN_STAGE2_EPOCHS=1
SMART_TIRE_DAILY_KM=40
FEDERATED_SIM_NODES=3
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# ── Daily Quotas (per API key) ──────────────────────────────────────────
GEMINI_DAILY_QUOTA=50
OPENWEATHER_DAILY_QUOTA=50
MAPS_DAILY_QUOTA=50
MAPILLARY_DAILY_QUOTA=50
