[TEMPLATE]
# Smart Tire Analyzer - Environment Variables
# Copy this file to .env and fill in your own values.
#
# ═══════════════════════════════════════════════════════════════════════════
# SECURITY WARNINGS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit .env to version control — it is already in .gitignore.
# 2. Generate strong secrets with:
#      python -c "import secrets; print(secrets.token_urlsafe(48))"
# 3. In production, enable AUTH_ENABLED=true AND set JWT_SECRET to a
#    strong random value (min 32 chars).
# 4. ALWAYS use HTTPS behind a TLS-terminating reverse proxy (nginx).
#    See deployment/docker/nginx.conf for a production TLS config.
# 5. API keys for third-party services (Gemini, Google Maps, etc.) are
#    stored encrypted at rest (AES-256-GCM Fernet derived from JWT_SECRET).
# 6. User-provided API keys are NEVER stored in the browser's localStorage.
#    The frontend only stores boolean preference flags.
# ═══════════════════════════════════════════════════════════════════════════

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth (required for login/sessions)
NEXTAUTH_URL=http://localhost:8081
# Generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production

# Google OAuth (optional - leave empty for dev mode with local credentials)
# Get keys at https://console.cloud.google.com/apis/credentials
# OAuth client secrets are stored server-side only - NEVER in the browser
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public copy - the client-side login page reads this to know real OAuth is available
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}

# Live chat LLM. Gemini uses the GEMINI_API_KEYS value below and does not need Ollama.
LIVE_CHAT_PROVIDER=gemini
LIVE_CHAT_MODEL=gemini-2.5-flash
LIVE_CHAT_REQUEST_TIMEOUT_MS=45000

# Hosted Llama option through Groq, OpenRouter, or another OpenAI-compatible API.
# LIVE_CHAT_PROVIDER=openai-compatible
# LIVE_CHAT_API_BASE_URL=https://api.groq.com/openai/v1
# LIVE_CHAT_API_KEY=
# LIVE_CHAT_MODEL=llama3-8b-8192

# Local route-aware driving advice for backend analysis.
# Start Ollama and pull the model with: ollama pull llama3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# Gemini AI API keys. Use comma-separated values for rotation.
# User-provided keys are encrypted at rest (AES-256-GCM) in the database
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# Google Maps API keys. Use comma-separated values for rotation.
GOOGLE_MAPS_API_KEYS=

# OpenWeatherMap API keys. Use comma-separated values for rotation.
OPENWEATHER_API_KEYS=

# Mapillary API keys. Use comma-separated values for rotation.
MAPILLARY_API_KEYS=

# Database
# For production, use PostgreSQL with TLS connection:
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/smart_tire
# Passwords in DATABASE_URL are read at startup - ensure file permissions are restricted
DATABASE_URL=sqlite+aiosqlite:///./smart_tire.db

# TLS / HTTPS
# Enable HTTPS by setting ENABLE_HTTPS=true and DOMAIN to your domain.
# Development: bash scripts/generate_dev_certs.sh (generates self-signed certs)
# Production:  bash scripts/setup_production_certs.sh your-domain.com
DOMAIN=localhost
ENABLE_HTTPS=false

# Backend server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
BACKEND_CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Authentication (REQUIRED for production deployment)
# Enable authentication and set a strong JWT_SECRET before deploying
# to any internet-accessible environment.
#
# Generate JWT_SECRET with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# When AUTH_ENABLED=true, JWT_SECRET must be at least 32 characters.
# The JWT_SECRET is also used to derive the Fernet key for encrypting
# user API keys at rest in the database.
AUTH_ENABLED=false
API_KEY=
JWT_SECRET=
JWT_ISSUER=smart-tire-analyzer

# Image optimizer (runs before inference / continuous-learning storage)
IMAGE_OPTIMIZER_ENABLED=true
IMAGE_OPTIMIZER_MAX_DIMENSION=2048

# Notifications (email, Slack, or generic webhook)
NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=smart-tire@localhost
NOTIFICATION_EMAIL_TO=
SLACK_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=

# Model settings
CONFIDENCE_THRESHOLD=0.70
BLUR_THRESHOLD=60
RETRAIN_THRESHOLD=10
AUTO_RETRAIN=true
AUTO_RETRAIN_TRAIN=true
AUTO_RETRAIN_STAGE1_EPOCHS=2
AUTO_RETRAIN_STAGE2_EPOCHS=1
MODEL_VERSION=1.0.0
SMART_TIRE_DAILY_KM=40
FEDERATED_SIM_NODES=3

# API rate limits
GEMINI_DAILY_QUOTA=50
OPENWEATHER_DAILY_QUOTA=50
MAPS_DAILY_QUOTA=50
MAPILLARY_DAILY_QUOTA=50
