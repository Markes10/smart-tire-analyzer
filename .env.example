# Smart Tire Analyzer - Environment Variables
# Copy this file to .env and fill in your own values.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Live chat LLM. Gemini uses the GEMINI_API_KEYS value below and does not need Ollama.
LIVE_CHAT_PROVIDER=gemini
LIVE_CHAT_MODEL=gemini-2.5-flash
LIVE_CHAT_REQUEST_TIMEOUT_MS=45000

# Hosted Llama option through Groq, OpenRouter, or another OpenAI-compatible API.
# LIVE_CHAT_PROVIDER=openai-compatible
# LIVE_CHAT_API_BASE_URL=https://api.groq.com/openai/v1
# LIVE_CHAT_API_KEY=
# LIVE_CHAT_MODEL=llama3-8b-8192

# Local route-aware driving advice for backend analysis.
# Start Ollama and pull the model with: ollama pull llama3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# Gemini AI API keys. Use comma-separated values for rotation.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# Google Maps API keys. Use comma-separated values for rotation.
GOOGLE_MAPS_API_KEYS=

# OpenWeatherMap API keys. Use comma-separated values for rotation.
OPENWEATHER_API_KEYS=

# Mapillary API keys. Use comma-separated values for rotation.
MAPILLARY_API_KEYS=

# Database
DATABASE_URL=sqlite+aiosqlite:///./smart_tire.db

# Backend server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
BACKEND_CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Optional security demo. Keep disabled for easiest local runs.
AUTH_ENABLED=false
API_KEY=
JWT_SECRET=smart-tire-local-demo-secret
JWT_ISSUER=smart-tire-analyzer

# Image optimizer (runs before inference / continuous-learning storage)
IMAGE_OPTIMIZER_ENABLED=true
IMAGE_OPTIMIZER_MAX_DIMENSION=2048

# Notifications (email, Slack, or generic webhook)
NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=smart-tire@localhost
NOTIFICATION_EMAIL_TO=
SLACK_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=

# Model settings
CONFIDENCE_THRESHOLD=0.70
BLUR_THRESHOLD=60
RETRAIN_THRESHOLD=10
AUTO_RETRAIN=true
AUTO_RETRAIN_TRAIN=true
AUTO_RETRAIN_STAGE1_EPOCHS=2
AUTO_RETRAIN_STAGE2_EPOCHS=1
MODEL_VERSION=1.0.0
SMART_TIRE_DAILY_KM=40
FEDERATED_SIM_NODES=3

# API rate limits
GEMINI_DAILY_QUOTA=50
OPENWEATHER_DAILY_QUOTA=50
MAPS_DAILY_QUOTA=50
MAPILLARY_DAILY_QUOTA=50
